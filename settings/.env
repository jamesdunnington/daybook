# ─────────────────────────────────────────────────────────────────────────────
# Daybook — environment variables
# Add these lines to your ~/n8n/.env  (or ~/daybook/.env if running standalone)
# All vars are prefixed DAYBOOK_ so they don't clash with n8n/postiz/keila vars.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DAYBOOK_DB_USER=daybook
DAYBOOK_DB_PASSWORD=CHANGE_ME_strong_password
DAYBOOK_DB_NAME=daybook

# ── Auth (generate with: openssl rand -base64 32) ─────────────────────────────
DAYBOOK_AUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# ── GitHub (owner of ghcr.io images) ─────────────────────────────────────────
GITHUB_OWNER=jamesdunnington

# ── OpenRouter AI ─────────────────────────────────────────────────────────────
# Optional — users can set their own key in the app Settings page
DAYBOOK_OPENROUTER_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Optional — create a bot at https://t.me/BotFather
DAYBOOK_TELEGRAM_TOKEN=

# ── SMTP Email ────────────────────────────────────────────────────────────────
# Optional — leave blank to disable email notifications
DAYBOOK_SMTP_HOST=smtp.hostinger.com
DAYBOOK_SMTP_PORT=465
DAYBOOK_SMTP_USER=james@thecontentwarrior.work
DAYBOOK_SMTP_PASS=
DAYBOOK_SMTP_FROM=Daybook <james@thecontentwarrior.work>

# ── MCP API Key ───────────────────────────────────────────────────────────────
# Leave blank now. After first login go to Settings → API Keys,
# generate a key, then paste it here and run: docker compose up -d daybook-mcp
DAYBOOK_MCP_KEY=
