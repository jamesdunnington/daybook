# ─── Daybook Database ──────────────────────────────────────────────────────────
# These are scoped to Daybook's own postgres container.
# On a multi-stack VPS each app has its own prefixed vars to avoid confusion.
DAYBOOK_DB_USER=daybook
DAYBOOK_DB_PASSWORD=changeme_strong_password
DAYBOOK_DB_NAME=daybook

# ─── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_32_char_secret_here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── OpenRouter AI ─────────────────────────────────────────────────────────────
# Global fallback key. Users can override with their own key in Settings.
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC-your-bot-token

# ─── SMTP Email ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Daybook <your@gmail.com>

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
UPLOAD_DIR=./uploads

# ─── MCP Server ────────────────────────────────────────────────────────────────
# Generate an API key in the app Settings page, then paste it here
MCP_API_KEY=dk_xxxxxxxx_your_api_key

# ─── CI/CD (prod only) ─────────────────────────────────────────────────────────
GITHUB_OWNER=your_github_username
