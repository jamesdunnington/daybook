# ─────────────────────────────────────────────────────────────────────────────
# Append these two blocks to ~/n8n/Caddyfile
# Caddy reaches the containers via postiz-network by container name.
# ─────────────────────────────────────────────────────────────────────────────

daybook.thecontentwarrior.work {
    reverse_proxy daybook-app:3000
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    }
}

mcpdaybook.thecontentwarrior.work {
    reverse_proxy daybook-mcp:3001
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    }
}
