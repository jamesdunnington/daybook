# ─────────────────────────────────────────────────────────────────────────────
# Append these blocks to your existing ~/n8n/Caddyfile on the VPS.
# The app and mcp containers bind to 127.0.0.1:3010 / 127.0.0.1:3011,
# so Caddy reaches them via the host loopback interface.
# ─────────────────────────────────────────────────────────────────────────────

daybook.thecontentwarrior.work {
    reverse_proxy host.docker.internal:3010
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    }
}

mcpdaybook.thecontentwarrior.work {
    reverse_proxy host.docker.internal:3011
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    }
}
